{
  "name": "fastlat",
  "version": "1.0.0",
  "description": "FastLAT - Fast Log Analysis Tool",
  "main": "./out/main/index.js",
  "author": "FastLAT Team <team@fastlat.app>",
  "homepage": "https://github.com/fastlat/fastlat",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.node.json && electron .",
    "dev:renderer": "cd src/renderer && vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "cd src/renderer && vite build",
    "build:app": "npm run build && electron-builder",
    "start": "electron . --no-sandbox",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "dexie": "^4.0.11",
    "lodash-es": "^4.17.21",
    "minisearch": "^7.1.2",
    "uuid": "^11.1.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
